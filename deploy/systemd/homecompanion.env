# HomeCompanion systemd environment overrides
# Copy to: /etc/homecompanion/homecompanion.env

# Bind to all interfaces on port 5000.
ASPNETCORE_URLS=http://192.168.0.0:5000

# Optional: Increase host shutdown timeout if required by persistence/connectors.
DOTNET_HOSTBUILDER__SHUTDOWNTIMEOUTSECONDS=60
