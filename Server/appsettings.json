{
  "Comment": "Make sure to override with your local ~/.config/HomeCompanion.json file (or /etc/HomeCompanion.json on Linux)",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost",
  "Knx": {
    "Enable": true,
    "Connections": {
      "default": {
        "ConnectionString": "Type=IpRouting;KnxAddress=0.0.10",
        "MulticastAddress": "224.0.23.12",
        "Port": 3671
      }
    }
  },
  "OpenHAB": {
    "Enable": false,
    "WebSocket": "ws://localhost:8080/ws",
    "RestApi": "http://localhost:8080/rest/",
    "AccessToken": "",
    "SourceEntity": "HomeCompanion:ProductionInstance"
  },
  "Alerting": {
    "Enable": false,
    "SeverityRouting": {
      "Info": [
        "Email"
      ],
      "Warning": [
        "Email"
      ],
      "Critical": [
        "PushMessage"
      ],
      "Emergency": [
        "PushMessage",
        "Email"
      ]
    },
    "Fallbacks": {
      "WarningEmailToCriticalPushMessage": true
    },
    "PushMessage": {
      "Broker": "main",
      "Topic": "homecompanion/alerts/critical",
      "Qos": 1,
      "Retain": false,
      "ContentType": "application/json",
      "PublishResultTimeoutMs": 5000
    },
    "Email": {
      "WarningRecipients": [
        "alerts@example.org"
      ],
      "Smtp": {
        "Host": "smtp.example.org",
        "Port": 587,
        "UseStartTls": true,
        "User": "alerts@example.org",
        "Password": "change-me",
        "From": "alerts@example.org"
      },
      "Templates": {
        "WarningSubject": "[HomeCompanion] Warning: {AlertKey}",
        "InfoSubject": "[HomeCompanion] Info",
        "CriticalSubject": "[HomeCompanion] Critical: {AlertKey}",
        "Body": "Severity: {Severity}\\nAlertKey: {AlertKey}\\nMessage: {MessageShort}\\nDetails: {MessageLong}\\nCorrelationId: {CorrelationId}\\nMetadata:\\n{Metadata}"
      }
    },
    "NamedAlerts": {
      "PersistState": true,
      "DefaultReminderInterval": "00:15:00",
      "PerSeverityReminderInterval": {
        "Warning": "00:30:00",
        "Critical": "00:10:00",
        "Emergency": "00:05:00"
      }
    }
  },
  "HomeCompanion": {
    "Mcp": {
      "BearerToken": "change-me"
    }
  }
}
