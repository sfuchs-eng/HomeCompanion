@implements IDisposable
@using HomeCompanion.Diagnostics

<div class="diagnostic-node" style="margin-left: 20px;">
    <div class="node-header" @onclick="ToggleExpand" style="cursor: pointer; font-weight: bold;">
        <span>@(IsExpanded ? "▼" : "▶") @Node.Name</span>
    </div>

    @if (IsExpanded)
    {
        <div class="node-content">
            <!-- Render Records as a Grid/Table -->
            @if (Node.Records.Any())
            {
                <table class="table table-sm" style="margin: 10px 0; border: 1px solid #ddd;">
                    <thead>
                        <tr>
                            <th>Name&nbsp;<span style="margin-left: 10px; font-weight: normal; cursor: pointer;" @onclick="StateHasChanged">🔄</span></th>
                            <th>Value</th>
                            <th>Explanation</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in Node.Records)
                        {
                            <tr>
                                <td>@record.Name</td>
                                <td>@(record.Value?.FormattedValue ?? string.Empty)</td>
                                <td><span class="text-muted">@(record.Explanation ?? string.Empty)</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <!-- Render Children Recursively -->
            @foreach (var child in Node.Children)
            {
                <DiagnosticNode Node="child" />
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public required IDiagnosticResultNode Node { get; set; }

    [Parameter]
    public bool IsExpanded { get; set; } = false;

    private void ToggleExpand() => IsExpanded = !IsExpanded;

    protected override void OnInitialized()
    {
        foreach (var record in Node.Records.OfType<IDynamicDiagnosticRecord>())
        {
            record.Changed += OnRecordChanged;
        }
    }

    private string GetRecordValue(IDiagnosticRecord record) => 
        record.Value?.FormattedValue ?? "N/A";

    private void OnRecordChanged(object? sender, DiagnosticRecordChangedEventArgs e)
    {
        // Trigger UI update when a dynamic record changes
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        // Unsubscribe to prevent memory leaks
        foreach (var record in Node.Records.OfType<IDynamicDiagnosticRecord>())
        {
            record.Changed -= OnRecordChanged;
        }
    }
}